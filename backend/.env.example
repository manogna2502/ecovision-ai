# Copy this file to .env and fill in your real Supabase connection string.
# Get it from: Supabase project -> Project Settings -> Database -> Connection string -> URI
# Use the "Connection pooling" string (port 6543) for serverless/free-tier hosting like Render;
# use the direct connection (port 5432) if running locally without pooling issues.

DATABASE_URL=postgresql://postgres.your-project-ref:[email protected]:6543/postgres